{
  "dashboard": {
    "id": null,
    "title": "Kafka Overview",
    "tags": ["messenger", "kafka"],
    "timezone": "utc",
    "schemaVersion": 36,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Consumer Lag",
        "type": "timeseries",
        "targets": [
          {
            "expr": "kafka_consumer_group_lag",
            "legendFormat": "{{topic}} / {{group}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Partition Lag",
        "type": "timeseries",
        "targets": [
          {
            "expr": "kafka_consumergroup_lag",
            "legendFormat": "{{topic}}-{{partition}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Throughput (msg/s)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(kafka_server_brokertopicmetrics_messagesin_total[5m])",
            "legendFormat": "{{topic}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      }
    ]
  }
}
