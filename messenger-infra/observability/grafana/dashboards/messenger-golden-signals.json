{
  "dashboard": {
    "id": null,
    "title": "Messenger Golden Signals",
    "tags": ["messenger", "golden-signals"],
    "timezone": "utc",
    "schemaVersion": 36,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Latency p95",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "RPS",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
      },
      {
        "id": 3,
        "title": "Errors 5xx %",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
      },
      {
        "id": 4,
        "title": "Active WS Connections",
        "type": "timeseries",
        "targets": [
          {
            "expr": "active_websocket_connections",
            "legendFormat": "Realtime Gateway"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 5,
        "title": "Saturation (CPU/Memory)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "container_cpu_usage_seconds_total",
            "legendFormat": "CPU {{pod}}"
          },
          {
            "expr": "container_memory_working_set_bytes",
            "legendFormat": "Memory {{pod}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ]
  }
}
