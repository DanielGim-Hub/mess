apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaUser
metadata:
  name: messenger-app
  namespace: {{ strimzi_namespace }}
  labels:
    strimzi.io/cluster: {{ kafka_cluster_name }}
spec:
  authentication:
    type: scram-sha-512
  authorization:
    type: simple
    acls:
      - resource:
          type: topic
          name: message.created
          patternType: literal
        operation: All
      - resource:
          type: topic
          name: chat.events
          patternType: literal
        operation: All
      - resource:
          type: topic
          name: receipt.events
          patternType: literal
        operation: All
      - resource:
          type: topic
          name: presence.events
          patternType: literal
        operation: All
      - resource:
          type: group
          name: '*'
          patternType: literal
        operation: All
